{
  "name": "construction-company-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate-icons && vite build && npm run generate-sitemap",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "analyze": "node scripts/analyze-bundle.js",
    "lighthouse": "lighthouse http://localhost:3000 --view",
    "precommit": "lint-staged && npm run test",
    "postbuild": "npm run analyze",
    "generate-icons": "ts-node scripts/generate-icons.ts",
    "generate-sitemap": "ts-node scripts/generate-sitemap.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@react-google-maps/api": "^2.19.3",
    "@react-three/drei": "^9.99.0",
    "@react-three/fiber": "^8.15.16",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-ga4": "^2.1.0",
    "react-google-recaptcha": "^3.1.0",
    "react-helmet-async": "^2.0.5",
    "react-intersection-observer": "^9.8.1",
    "react-router-dom": "^6.22.2",
    "swiper": "^11.2.2",
    "three": "^0.161.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.161.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.0.4",
    "@vitest/ui": "^3.0.4",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^22.1.0",
    "lighthouse": "^9.6.8",
    "lint-staged": "^13.2.0",
    "msw": "^2.0.0",
    "postcss": "^8.4.35",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.4",
    "workbox-core": "^7.3.0",
    "workbox-expiration": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  }
}
